@page "{id:int}"
@model ItemRazorV1.Pages.Item.EditItemModel
@{
}

<form method="post" enctype="multipart/form-data">
	<div class="form-group">
		<label asp-for="Item.Id" class="control-lable"></label>
		<input asp-for="Item.Id" class="form-control" readonly="@(true)"/>
	</div>
	<div class="form-group">
		<label asp-for="Item.Name" class="control-lable"></label>
		<input asp-for="Item.Name" class="form-control" />
		<span asp-validation-for="Item.Name" class="text-danger"></span>
	</div>
	<div class="form-group">
		<label asp-for="@Model.Item.Description" class="control-label"></label>
		<input asp-for="@Model.Item.Description" class="form-control" />
		<span asp-validation-for="@Model.Item.Name" class="text-danger"></span>
	</div>
	<div class="form-group">
		<label asp-for="Item.Price" class="control-lable"></label>
		<input asp-for="Item.Price" class="form-control" />
		<span asp-validation-for="Item.Price" class="text-danger"></span>
	</div>
	<div class="form-group">
		<label asp-for="@Model.Photo" class="control-label"></label>
		<div class="custom-file">
			<input asp-for="@Model.Photo" class="custom-file-input form-control" />
			<label class="custom-file-label">Gem Billede</label>
		</div>
	</div>

	<p>
		<div class="form-group">
			<input type="submit" value="Update" class="btn btn-primary" />
		</div>
	</p>
</form>

<p>
	<a asp-page="/Item/GetAllItems">Back to List</a>
</p>
